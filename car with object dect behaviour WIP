  currentNode = targetNode;
  sendPosition(currentNode);
  delay(100000);
}

void FindParking() {
  Serial.println("=== ENTERING PARKING MODE ===");
  
  while (true) {  // Keep searching until obstacle found
    // Read distance
    float distance = getDistance();
    Serial.print("Distance: ");
    Serial.println(distance);
    
    // Check for obstacle
    if (distance < stopDistance) {
      Serial.print("OBSTACLE at ");
      Serial.print(distance);
      Serial.println(" cm - Initiating parking!");
      Parking();
      return;  // Exit after parking
    }
    
    // Just go straight - no line following
    moveForward(200, 200);
    
    delay(50);  // Small delay between checks
  }
}
