// ================= MAIN LOOP =================
void loop() {
  
  float distance = getDistance();
  
  // Obstacle detection with cooldown
  if (distance < stopDistance && (millis() - lastTurnTime > turnCooldown)) {
    Serial.print("OBSTACLE at ");
    Serial.print(distance);
    Serial.println(" cm - Obstacle detected!");
    
    // Handle obstacle: update graph and reroute
    handleObstacleDetection();
    
    lastTurnTime = millis();
    return;
  }

  bool onLine[5];
  int sensorsActive = 0;
  for (int i = 0; i < 5; i++) {
    AnalogValue[i] = analogRead(AnalogPin[i]);
    onLine[i] = (AnalogValue[i] < threshold);
    if (onLine[i]) sensorsActive++;
  }

  if (sensorsActive >= 3) {
    stopMotors();
    delay(100);
    handleIntersection();
  }
  else if (onLine[2] && !onLine[0] && !onLine[4]) {
    moveForward(maxSpeed, maxSpeed);
  }
  else if (onLine[1]) {
    moveForward(110, cruiseSpeed);
  }
  else if (onLine[3]) {
    moveForward(cruiseSpeed, 110);
  }
  else if (onLine[0]) {
    moveForward(10, 200);
  }
  else if (onLine[4]) {
    moveForward(200, 10);
  }
  else {
    moveForward(cruiseSpeed, cruiseSpeed);
  }
}

// ================= OBSTACLE HANDLING =================
void handleObstacleDetection() {
  Serial.println("\n=== OBSTACLE DETECTED - INITIATING REROUTE ===");
  
  // Stop the robot
  stopMotors();
  delay(200);
  
  // Get current and target nodes as integers
  int currentNodeInt = currentNode.toInt();
  int targetNodeInt = targetNode.toInt();
  
  // Update graph with obstacle penalty (bidirectional)
  updateGraphWithObstacle(currentNodeInt, targetNodeInt);
  
  // Perform 180-degree turn to go back
  Serial.println("Performing 180-degree turn to return to previous node...");
  perform180Turn();
  
  // Swap current and previous (we're going back)
  String temp = currentNode;
  currentNode = previousNode;
  previousNode = temp;
  
  // Send updated position
  sendPosition(currentNode);
  
  // Recalculate the route from current position
  recalculateRoute();
  
  Serial.println("=== REROUTE COMPLETE ===\n");
}

void updateGraphWithObstacle(int fromNode, int toNode) {
  Serial.print("Updating graph: Adding penalty to path ");
  Serial.print(fromNode);
  Serial.print(" <-> ");
  Serial.println(toNode);
  
  // Add penalty to both directions
  if (graph[fromNode][toNode] > 0) {
    graph[fromNode][toNode] += OBSTACLE_PENALTY;
    Serial.print("  Updated weight from ");
    Serial.print(fromNode);
    Serial.print(" to ");
    Serial.print(toNode);
    Serial.print(": ");
    Serial.println(graph[fromNode][toNode]);
  }
  
  if (graph[toNode][fromNode] > 0) {
    graph[toNode][fromNode] += OBSTACLE_PENALTY;
    Serial.print("  Updated weight from ");
    Serial.print(toNode);
    Serial.print(" to ");
    Serial.print(fromNode);
    Serial.print(": ");
    Serial.println(graph[toNode][fromNode]);
  }
}

void recalculateRoute() {
  Serial.println("Recalculating route from current position...");
  
  // Get route from server (waypoints)
  String serverResponse = getRouteFromServer();
  
  if (serverResponse.length() > 0) {
    // Build new path using updated graph
    remainingRoute = buildPathFromWaypoints(serverResponse);
    
    Serial.print("New route calculated: ");
    Serial.println(remainingRoute);
    
    // Pop the next target
    popNextTarget();
    
    Serial.print("Next target after reroute: ");
    Serial.println(targetNode);
  } else {
    Serial.println("ERROR: Could not get route from server!");
  }
}

// ================= INTERSECTION HANDLER =================
void handleIntersection() {
  // Debug print showing Previous -> Current
  Serial.print("\n--- INTERSECTION DETECTED ---");
  Serial.print(" Coming from: ");
  Serial.print(previousNode);
  Serial.print(" | Currently at: ");
  Serial.println(currentNode);

  // FIXED: Send position to server at the intersection
  sendPosition(currentNode);

  // 1. Get New Route if Empty
  if (remainingRoute.length() == 0) {
    stopMotors();
    Serial.println("Fetching route from server...");
    String serverResponse = getRouteFromServer();
    if (serverResponse.length() > 0) {
      remainingRoute = buildPathFromWaypoints(serverResponse);
      Serial.print("Full Path: ");
      Serial.println(remainingRoute);
    }
  }

  // 2. Extract Next Target
  popNextTarget();

  // === SPECIFIC TRIGGER FOR NODE 7 -> 5 (PARKING) ===
  if (currentNode == "7" && targetNode == "5") {
    Serial.println(">>> DESTINATION REACHED: Node 7 to 5. Preparing for Parking Mode.");
    Serial.print("Approaching from Node ");
    Serial.println(previousNode);
    
    // Handle orientation based on where we came from
    if (previousNode == "1") {
      // Coming from Node 1 - already facing Node 5, go straight
      Serial.println("From Node 1: Already aligned, going STRAIGHT to Node 5");
      // No turn needed, just move forward to get on the line
      moveForward(cruiseSpeed, cruiseSpeed);
      delay(200);
    } 
    else if (previousNode == "3") {
      // Coming from Node 3 - need to turn RIGHT to face Node 5
      Serial.println("From Node 3: Turning RIGHT to align with Node 5");
      perform90Turn(false);  // false = right turn
      
      // After turning, align with the line
      Serial.println("Finding line after RIGHT turn...");
      int lineFound = 0;
      int attempts = 0;
      while (lineFound < 2 && attempts < 100) {
        int sensorsActive = 0;
        for (int i = 0; i < 5; i++) {
          if (analogRead(AnalogPin[i]) < threshold) sensorsActive++;
        }
        if (sensorsActive >= 1) lineFound++;
        spinRight(200);
        delay(100);
        moveForward(150, 150);
        delay(20);
        attempts++;
      }
      Serial.println("Line acquired after turn!");
    } 
    else if (previousNode == "4") {
      // Coming from Node 4 - need to turn LEFT to face Node 5
      Serial.println("From Node 4: Turning LEFT to align with Node 5");
      perform90Turn(true);  // true = left turn
      
      // After turning, align with the line
      Serial.println("Finding line after LEFT turn...");
      int lineFound = 0;
      int attempts = 0;
      while (lineFound < 2 && attempts < 100) {
        int sensorsActive = 0;
        for (int i = 0; i < 5; i++) {
          if (analogRead(AnalogPin[i]) < threshold) sensorsActive++;
        }
        if (sensorsActive >= 1) lineFound++;
          spinLeft(200);
          delay(100);
        moveForward(150, 150);
        delay(20);
        attempts++;
      }
      Serial.println("Line acquired after turn!");
    }
    
    // Update position tracking
    previousNode = currentNode;
    currentNode = targetNode;
    
    // FIXED: Send position after moving to Node 5
    sendPosition(currentNode);
    
    // Now properly aligned on the line towards Node 5
    Serial.println("Aligned and on line! Starting parking search...");
    stopMotors();
    delay(300);
    FindParking(); 
    return; 
  }

  // 3. Skip Redundant Nodes
  while (targetNode == currentNode && remainingRoute.length() > 0) {
    Serial.print("Skipping redundant node: ");
    Serial.println(targetNode);
    popNextTarget();
  }

  // If nowhere to go, stop.
  if (targetNode == currentNode || targetNode == "") {
    stopMotors();
    Serial.println("=== ROUTE COMPLETE ===");
    return;
  }

  Serial.print("Next Target: ");
  Serial.println(targetNode);

  // FIXED: Check if target equals previous (need 180 turn)
  if (targetNode == previousNode) {
    Serial.println(">>> TARGET EQUALS PREVIOUS NODE - 180° TURN REQUIRED");
    perform180Turn();
    
    // Update memory after 180 turn
    previousNode = currentNode;
    currentNode = targetNode;
    
    // FIXED: Send position after 180 turn
    sendPosition(currentNode);
    
    Serial.print("Memory updated after 180 -> Previous: ");
    Serial.print(previousNode);
    Serial.print(" | Current: ");
    Serial.println(currentNode);
    return;
  }

  // 4. CHECK IF STRAIGHT PATH
  if (isPathStraight(currentNode, targetNode)) {
    Serial.println(">>> CONTINUING STRAIGHT");
    moveForward(maxSpeed, maxSpeed);
    delay(150);
    
    previousNode = currentNode;
    currentNode = targetNode;
    
    // FIXED: Send position after moving straight
    sendPosition(currentNode);
    return;
  }

  // 5. EXECUTE TURN
  decideTurn(previousNode, currentNode, targetNode);

  // 6. Update Memory
  previousNode = currentNode;
  currentNode = targetNode;
  
  // FIXED: Send position after turn
  sendPosition(currentNode);
  
  Serial.print("Memory updated -> Previous: ");
  Serial.print(previousNode);
  Serial.print(" | Current: ");
  Serial.println(currentNode);
}

// ================= IMPROVED TURNING LOGIC =================
void decideTurn(String from, String current, String to) {
  Serial.print("TURN DECISION: from=");
  Serial.print(from);
  Serial.print(" current=");
  Serial.print(current);
  Serial.print(" to=");
  Serial.println(to);

  // REMOVED: The 180-turn check is now handled in handleIntersection()
  // This prevents duplicate 180-turn logic

  bool isLeft = false;
  bool foundMatch = false;

  // NODE 6 (Right Junc)
  if (current == "6") {
    if (to == "0") {
      if (from == "1") { isLeft = false; foundMatch = true; }
    } else if (to == "1") {
      if (from == "0") { isLeft = true; foundMatch = true; }
      else if (from == "2") { isLeft = false; foundMatch = true; }
    } else if (to == "2") {
      if (from == "1") { isLeft = true; foundMatch = true; }
    }
  }
  // NODE 7 (Left Junc)
  else if (current == "7") {
    if (to == "1") {
      if (from == "4") { isLeft = true; foundMatch = true; }
      else if (from == "3") { isLeft = false; foundMatch = true; }
    } else if (to == "3") {
      if (from == "1") { isLeft = false; foundMatch = true; }
      else if (from == "4") { isLeft = false; foundMatch = true; }
    } else if (to == "4") {
      if (from == "1") { isLeft = true; foundMatch = true; }
      else if (from == "3") { isLeft = true; foundMatch = true; }
    } else if (to == "5") {
      if (from == "3") { isLeft = false; foundMatch = true; }
      else if (from == "4") { isLeft = true; foundMatch = true; }
    }
  }

  // Execute the turn
  if (foundMatch) {
    if (isLeft) {
      Serial.println("Action: 90° LEFT Turn");
      perform90Turn(true);
    } else {
      Serial.println("Action: 90° RIGHT Turn");
      perform90Turn(false);
    }
  } else {
    Serial.println("WARNING: No turn logic matched! Go straight");
    moveForward(maxSpeed, maxSpeed);
    delay(200);
  }
}

void perform180Turn() {
  // Stop first
  stopMotors();
  delay(300);
  
  // Back up slightly
  motorReverse(150);
  delay(300);
  
  // Turn enough to get OFF the line first
  spinRight(200);
  delay(700);
  
  // Keep turning until we find the line again (but with timeout)
  int sensorsActive = 0;
  int turnAttempts = 0;
  int maxAttempts = 100;  // Prevent infinite loop
  
  while (sensorsActive < 1 && turnAttempts < maxAttempts) {
    spinRight(200);
    
    // Check sensors
    sensorsActive = 0;
    for (int i = 0; i < 5; i++) {
      if (analogRead(AnalogPin[i]) < threshold) sensorsActive++;
    }
    
    turnAttempts++;
    delay(50);  // Longer delay between checks
  }
  
  Serial.print("Turn complete. Attempts: ");
  Serial.println(turnAttempts);
  
  // Stop after finding line
  stopMotors();
  delay(300);
  
  // Move forward a bit to stabilize
  moveForward(200, 200);
  delay(100);
}

// === 90 DEGREE TURN CODE ===
void perform90Turn(bool isLeft) {
  stopMotors();
  delay(300);

  moveForward(200, 200);
  delay(100);

  if (isLeft)
    spinLeft(junctionSpinSpeed);
  else
    spinRight(junctionSpinSpeed);
  
  delay(400);

  int sensorsActive = 0;
  int turnAttempts = 0;
  int maxAttempts = 100;

  while (sensorsActive < 1 && turnAttempts < maxAttempts) {
    if (isLeft)
      spinLeft(junctionSpinSpeed);
    else
      spinRight(junctionSpinSpeed);

    sensorsActive = 0;
    for (int i = 0; i < 5; i++) {
      if (analogRead(AnalogPin[i]) < threshold) sensorsActive++;
    }
    turnAttempts++;
    delay(40);
  }

  stopMotors();
  delay(300);
}

// ================= HELPER: DETECT STRAIGHT PATHS =================
bool isPathStraight(String from, String to) {
  // Node 0 <-> Node 4 (straight line)
  if (from == "0" && to == "4") return true;
  if (from == "4" && to == "0") return true;
  
  // Node 7 -> Node 5 or Node 1 (straight)
  if (from == "7" && (to == "5" || to == "1")) return true;
  
  // Node 5 -> Node 7 (straight back)
  if (from == "5" && to == "7") return true;
  
  // Node 1 -> Node 7 (straight back)
  if (from == "1" && to == "7") return true;
  
  return false;
}

// ================= IR DISTANCE SENSOR =================
float getDistance() {
  // Average multiple readings to reduce noise
  float rawSum = 0;
  for(int i = 0; i < 10; i++) {
    rawSum += analogRead(irSensorPin);
    delay(1);
  }
  float averageADC = rawSum / 10.0;
  
  // Convert ADC value to voltage
  float voltage = (averageADC * vRef) / adcRes;
  
  // Handle very low voltage readings (no object detected)
  if (voltage < 0.4) return 999.0;
  
  // Calculate distance using power formula for GP2Y0A41SK (4cm-30cm range)
  float distanceCM = 13.0 * pow(voltage, -1.10);
  
  // Constrain to sensor's valid range
  if (distanceCM > 30) distanceCM = 999.0;
  if (distanceCM < 4) distanceCM = 4.0;
  
  return distanceCM;
}

