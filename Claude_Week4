// ================= MAIN LOOP =================
void loop() {
  long distance = getDistance();

  // Obstacle Handling
  if (distance < stopDistance && distance > 0) {
    consecutiveDetections++;
    if (consecutiveDetections >= requiredDetections) {
      stopMotors();
      Serial.println("Obstacle! Waiting...");
      delay(300);
      consecutiveDetections = 0;
      return;
    }
  } else {
    consecutiveDetections = 0;
  }

  // Line Sensor Reading
  bool onLine[5];
  int sensorsActive = 0;

  for (int i = 0; i < 5; i++) {
    AnalogValue[i] = analogRead(AnalogPin[i]);
    onLine[i] = (AnalogValue[i] < threshold);
    if (onLine[i]) sensorsActive++;
  }

  // INTERSECTION DETECTION
  if (sensorsActive >= 3) {
    stopMotors();
    delay(100); 
    handleIntersection();   
  }
  // ===== LINE FOLLOWING LOGIC =====
  else if (onLine[2] && !onLine[0] && !onLine[4]) {
    moveForward(maxSpeed, maxSpeed);
  }
  else if (onLine[1]) {
    moveForward(120, cruiseSpeed);
  }
  else if (onLine[3]) {
    moveForward(cruiseSpeed, 120);
  }
  else if (onLine[0]) {
    moveForward(40, 180); 
  }
  else if (onLine[4]) {
    moveForward(180, 40); 
  }
  else {
    moveForward(cruiseSpeed, cruiseSpeed);
  }
}

// ================= INTERSECTION HANDLER =================
void handleIntersection() {
  Serial.print("\n========================================");
  Serial.print("\n   INTERSECTION AT NODE "); Serial.println(currentNode);
  Serial.print("   Came from: Node "); Serial.println(previousNode);
  Serial.println("========================================");
  
  sendPosition(currentNode);

  // 1. Get New Route if Empty
  if (remainingRoute.length() == 0 && targetNode == currentNode) {
    stopMotors(); 
    Serial.println("\nFetching new route from server...");
    String serverResponse = getRouteFromServer();
    
    if (serverResponse.length() > 0) {
       remainingRoute = buildPathFromWaypoints(serverResponse);
       Serial.print("Server waypoints converted to path: ");
       Serial.println(remainingRoute);
       
       // Get first target from new route
       popNextTarget();
    } else {
      Serial.println("No route received from server!");
      return;
    }
  }
  // If we still have route but need next target
  else if (targetNode == currentNode && remainingRoute.length() > 0) {
    popNextTarget();
  }

  // Skip any redundant nodes
  while (targetNode == currentNode && remainingRoute.length() > 0) {
      Serial.print("Skipping redundant node: "); Serial.println(targetNode);
      popNextTarget();
  }

  // If nowhere to go, stop
  if (targetNode == currentNode || targetNode == "") {
      stopMotors();
      Serial.println("========================================");
      Serial.println("      ROUTE COMPLETE - STOPPING");
      Serial.println("========================================\n");
      return; 
  }

  Serial.print("\n>> Next Target: Node "); Serial.println(targetNode);

  // 4. CALCULATE TURN ANGLE
  int fromNodeInt = previousNode.toInt();
  int currentNodeInt = currentNode.toInt();
  int targetNodeInt = targetNode.toInt();
  
  float turnAngle = calculateTurnAngle(fromNodeInt, currentNodeInt, targetNodeInt);
  
  Serial.print(">> Turn calculation: "); Serial.print(turnAngle); Serial.println("°");

  // 5. EXECUTE TURN OR GO STRAIGHT
  if (abs(turnAngle) < 20) {  // Tolerance for "straight"
      Serial.println(">> Action: CONTINUE STRAIGHT\n");
      moveForward(maxSpeed, maxSpeed); 
      delay(150); 
  } else {
      performTurn(turnAngle);
  }

  // 6. UPDATE TRACKING VARIABLES
  // The node we're AT becomes where we CAME FROM
  // The node we're GOING TO becomes where we ARE
  previousNode = currentNode;
  currentNode = targetNode;
  
  Serial.print(">> Updated state - Now at: Node "); Serial.print(currentNode);
  Serial.print(" | Came from: Node "); Serial.println(previousNode);
  Serial.println("========================================\n");
}

// ================= TURN ANGLE CALCULATION =================
// Calculate the turn angle needed at an intersection
// fromNode: the node we came from (our entry direction)
// currentNode: where we are now (the intersection)
// toNode: where we want to go (our exit direction)
float calculateTurnAngle(int fromNode, int currentNode, int toNode) {
  // Get the angle of our current heading (direction we're traveling)
  float currentHeading = getAngleBetweenNodes(fromNode, currentNode);
  
  // Get the angle we need to be facing (direction to target)
  float targetHeading = getAngleBetweenNodes(currentNode, toNode);
  
  // Calculate the difference
  float turnAngle = normalizeAngle(targetHeading - currentHeading);
  
  Serial.print("   Heading from Node "); Serial.print(fromNode);
  Serial.print(" -> "); Serial.print(currentNode);
  Serial.print(" = "); Serial.print(currentHeading); Serial.println("°");
  
  Serial.print("   Need to face Node "); Serial.print(currentNode);
  Serial.print(" -> "); Serial.print(toNode);
  Serial.print(" = "); Serial.print(targetHeading); Serial.println("°");
  
  return turnAngle;
}

// Calculate the angle between two nodes (returns 0-360°)
// 0° = East (right), 90° = North (up), 180° = West (left), 270° = South (down)
float getAngleBetweenNodes(int fromNode, int toNode) {
  float dx = nodePos[toNode].x - nodePos[fromNode].x;
  float dy = nodePos[toNode].y - nodePos[fromNode].y;
  
  // atan2 returns -π to π, convert to 0-360°
  float angle = atan2(dy, dx) * 180.0 / PI;
  if (angle < 0) angle += 360;
  
  return angle;
}

// Normalize angle to -180 to +180 range
// Positive = turn left, Negative = turn right
float normalizeAngle(float angle) {
  while (angle > 180) angle -= 360;
  while (angle < -180) angle += 360;
  return angle;
}

// ================= DYNAMIC TURN EXECUTION =================
void performTurn(float turnAngle) {
  stopMotors();
  delay(300);
  
  // Determine turn type and direction
  bool isLeftTurn = (turnAngle > 0);
  float absAngle = abs(turnAngle);
  
  Serial.print(">> Executing: ");
  
  // For ~180° turns (U-turn)
  if (absAngle > 135) {
    Serial.print("180° U-TURN (");
    Serial.print(isLeftTurn ? "LEFT" : "RIGHT");
    Serial.println(")");
    
    // Reverse slightly
    motorReverse(150);
    delay(300);
    
    // Spin in the appropriate direction
    if (isLeftTurn) {
      spinLeft(junctionSpinSpeed);
    } else {
      spinRight(junctionSpinSpeed);
    }
    delay(700);
    
    // Wait for line detection
    int sensorsActive = 0;
    int turnAttempts = 0;
    int maxAttempts = 60;
    
    while (sensorsActive < 1 && turnAttempts < maxAttempts) {
      if (isLeftTurn) {
        spinLeft(junctionSpinSpeed);
      } else {
        spinRight(junctionSpinSpeed);
      }
      
      sensorsActive = 0;
      for (int i = 0; i < 5; i++) {
        if (analogRead(AnalogPin[i]) < threshold) sensorsActive++;
      }
      
      turnAttempts++;
      delay(40);
    }
    
    Serial.println("   U-turn complete!");
  }
  // For ~90° turns
  else if (absAngle > 45) {
    Serial.print("90° ");
    Serial.print(isLeftTurn ? "LEFT" : "RIGHT");
    Serial.println(" TURN");
    
    // Move forward slightly to clear intersection
    moveForward(200, 200);
    delay(150);
    
    // Spin
    if (isLeftTurn) {
      spinLeft(junctionSpinSpeed);
    } else {
      spinRight(junctionSpinSpeed);
    }
    delay(400);
    
    // Wait for line detection
    int sensorsActive = 0;
    int turnAttempts = 0;
    int maxAttempts = 60;
    
    while (sensorsActive < 1 && turnAttempts < maxAttempts) {
      if (isLeftTurn) {
        spinLeft(junctionSpinSpeed);
      } else {
        spinRight(junctionSpinSpeed);
      }
      
      sensorsActive = 0;
      for (int i = 0; i < 5; i++) {
        if (analogRead(AnalogPin[i]) < threshold) sensorsActive++;
      }
      
      turnAttempts++;
      delay(40);
    }
    
    Serial.println("   90° turn complete!");
  }
  // For slight adjustments
  else {
    Serial.println("SLIGHT ADJUSTMENT");
    moveForward(200, 200);
    delay(100);
  }
  
  stopMotors();
  delay(300);
}

// ================= WIFI & SERVER =================
void connectToWiFi() {
  if(WiFi.status() == WL_CONNECTED) return;
  Serial.print("Connecting to network: ");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { Serial.print("."); delay(300); }
  Serial.println("\nWiFi Connected!");
}

void sendPosition(String position) {
  if (!connectToServer()) return;
  String postBody = "position=" + position;
  client.println("POST /api/arrived/" + teamID + " HTTP/1.1");
  client.println("Host: " + String(server));
  client.println("Content-Type: application/x-www-form-urlencoded");
  client.print("Content-Length: "); client.println(postBody.length());
  client.println("Connection: close");
  client.println();
  client.println(postBody);
  readResponse(); 
  client.stop();
}

String getRouteFromServer() {
  if (!connectToServer()) return "";
  client.println("GET /api/getRoute/" + teamID + " HTTP/1.1");
  client.println("Host: " + String(server));
  client.println("Connection: close");
  client.println();
  String response = readResponse();
  client.stop();
  int split = response.indexOf("\r\n\r\n");
  if (split == -1) return "";
  String body = response.substring(split + 4);
  body.trim();
  return body;
}

bool connectToServer() { 
  if (client.connect(server, port)) {
    return true;
  }
  Serial.println("Server Connection FAILED!");
  return false;
}

String readResponse() {
  unsigned long timeout = millis();
  while (client.available() == 0) { if (millis() - timeout > 3000) return ""; }
  String res = "";
  while(client.available()) { res += (char)client.read(); }
  return res;
}

// ================= ROUTE BUILDER (DIJKSTRA HELPERS) =================
String buildPathFromWaypoints(String waypoints) {
    String fullPath = "";
    int currentSearchNode = currentNode.toInt();
    waypoints.trim();
    
    while (waypoints.length() > 0) {
        int commaIndex = waypoints.indexOf(',');
        String checkpointStr;
        if (commaIndex == -1) { 
            checkpointStr = waypoints; 
            waypoints = ""; 
        } else { 
            checkpointStr = waypoints.substring(0, commaIndex); 
            waypoints = waypoints.substring(commaIndex + 1); 
        }
        checkpointStr.trim();
        int nextCheckpoint = checkpointStr.toInt();

        if (nextCheckpoint == currentSearchNode) {
            continue; 
        }

        String segment = calculateDijkstraPath(currentSearchNode, nextCheckpoint);
        if (segment.length() > 0) {
            if (fullPath.length() > 0) fullPath += ",";
            fullPath += segment;
        }
        currentSearchNode = nextCheckpoint;
    }
    return fullPath;
}

String calculateDijkstraPath(int startNode, int endNode) {
    if (startNode == endNode) return "";
    int dist[V], parent[V]; bool sptSet[V];
    for (int i = 0; i < V; i++) { dist[i] = INF; sptSet[i] = false; parent[i] = -1; }
    dist[startNode] = 0;
    
    for (int count = 0; count < V - 1; count++) {
        int u = -1;
        for (int i = 0; i < V; i++) if (!sptSet[i] && (u == -1 || dist[i] < dist[u])) u = i;
        if (dist[u] == INF) break;
        sptSet[u] = true;
        
        for (int v = 0; v < V; v++) {
            if (!sptSet[v] && graph[u][v] && dist[u] != INF && dist[u] + graph[u][v] < dist[v]) {
                dist[v] = dist[u] + graph[u][v];
                parent[v] = u;
            }
        }
    }
    String path = ""; int curr = endNode;
    while (curr != -1) {
        if (curr == startNode) break; 
        if (path == "") path = String(curr); else path = String(curr) + "," + path;
        curr = parent[curr];
    }
    return path;
}

void popNextTarget() {
  remainingRoute.trim();
  if (remainingRoute.length() == 0) { targetNode = currentNode; return; }
  int commaIndex = remainingRoute.indexOf(',');
  if (commaIndex == -1) { targetNode = remainingRoute; remainingRoute = ""; } 
  else { targetNode = remainingRoute.substring(0, commaIndex); remainingRoute = remainingRoute.substring(commaIndex + 1); }
  targetNode.trim();
}

// ================= HARDWARE DRIVERS =================
long getDistance() {
  digitalWrite(trigPin, LOW); delayMicroseconds(2);
  digitalWrite(trigPin, HIGH); delayMicroseconds(10);
  digitalWrite(trigPin, LOW);
  long duration = pulseIn(echoPin, HIGH, 20000);
  return (duration == 0) ? 999 : (duration / 2) * 0.0343;
}

void moveForward(int left, int right) {
  digitalWrite(motorLeftPhase, HIGH); digitalWrite(motorRightPhase, HIGH);
  analogWrite(motorLeftPWM, left); analogWrite(motorRightPWM, right);
}

void motorReverse(int speed) {
  digitalWrite(motorLeftPhase, LOW); digitalWrite(motorRightPhase, LOW);
  analogWrite(motorLeftPWM, speed); analogWrite(motorRightPWM, speed);
}

void spinLeft(int speed) {
  digitalWrite(motorLeftPhase, LOW); digitalWrite(motorRightPhase, HIGH);
  analogWrite(motorLeftPWM, speed); analogWrite(motorRightPWM, speed);
}

void spinRight(int speed) {
  digitalWrite(motorLeftPhase, HIGH); digitalWrite(motorRightPhase, LOW);
  analogWrite(motorLeftPWM, speed); analogWrite(motorRightPWM, speed);
}

void stopMotors() {
  analogWrite(motorLeftPWM, 0); analogWrite(motorRightPWM, 0);
}
