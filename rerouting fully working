  pinMode(motorRightPWM,   OUTPUT);
  pinMode(motorRightPhase, OUTPUT);
  pinMode(irSensorPin,     INPUT);

  stopMotors();
  connectToWiFi();

  // NOTE: We do NOT send position here. We wait until we hit the line at Node 0.
